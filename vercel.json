{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/analytics", "destination": "/analytics.html" },
    { "source": "/agents",    "destination": "/agents.html" },
    { "source": "/billing",   "destination": "/billing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
